{
  "name": "solar-lead-management",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:web": "pnpm --filter @solar/web dev",
    "dev:api": "pnpm --filter @solar/api dev",
    "dev:mobile": "pnpm --filter @solar/mobile dev",
    "build:web": "pnpm --filter @solar/web build",
    "build:web:with-mapping": "pnpm --filter @solar/api districts:export:web && pnpm --filter @solar/web build",
    "build:web:mapping": "pnpm --filter @solar/api districts:export:web",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma"
  }
}
