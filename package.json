{
  "name": "solar-lead-management",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:web": "pnpm --filter @solar/web dev",
    "dev:api": "pnpm --filter @solar/api dev",
    "dev:api:worker": "pnpm --filter @solar/api dev:worker",
    "dev:mobile": "pnpm --filter @solar/mobile dev",
    "start:api": "pnpm --filter @solar/api start",
    "start:api:worker": "pnpm --filter @solar/api worker",
    "start:web": "pnpm --filter @solar/web start",
    "build:web": "pnpm --filter @solar/web build",
    "build:api": "pnpm --filter @solar/api build",
    "build:all": "pnpm --filter @solar/api build && pnpm --filter @solar/web build && pnpm --filter @solar/mobile typecheck",
    "build:web:with-mapping": "pnpm --filter @solar/api districts:export:web && pnpm --filter @solar/web build",
    "build:web:mapping": "pnpm --filter @solar/api districts:export:web",
    "prisma:generate": "pnpm --filter @solar/api prisma:generate",
    "prisma:db:push": "pnpm --filter @solar/api prisma:db:push",
    "prisma:db:push:force": "pnpm --filter @solar/api prisma:db:push:force",
    "deploy:web:vercel": "npx vercel --prod",
    "lint": "pnpm --filter @solar/shared lint && pnpm --filter @solar/api lint && pnpm --filter @solar/web lint && pnpm --filter @solar/mobile lint",
    "typecheck": "node scripts/typecheck-workspaces.cjs",
    "typecheck:all": "node scripts/typecheck-workspaces.cjs"
  },
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
