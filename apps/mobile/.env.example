# API URL (default deployed backend):
EXPO_PUBLIC_API_BASE_URL=https://solar-lead.onrender.com
# Local overrides (if needed):
# - Android emulator: http://10.0.2.2:4000
# - iOS simulator: http://localhost:4000
# - Physical device:  http://<YOUR_LAN_IP>:4000
EXPO_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_mobile_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_with_firebase_auth_domain
EXPO_PUBLIC_FIREBASE_PROJECT_ID=replace_with_firebase_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_with_firebase_storage_bucket
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_firebase_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=replace_with_firebase_mobile_app_id
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=replace_with_recaptcha_site_key
# Optional reCAPTCHA aliases supported in code:
EXPO_PUBLIC_GOOGLE_RECAPTCHA_SITE_KEY=
EXPO_PUBLIC_RECAPTCHA_SITEKEY=
EXPO_PUBLIC_TOKEN_PAYMENT_AMOUNT_INR=1000

# Mobile payment collection
# Preferred: direct QR image URL hosted on CDN/S3.
EXPO_PUBLIC_COMPANY_UPI_QR_URL=
# Fallback: if QR image URL is not set, app generates a QR from UPI ID.
EXPO_PUBLIC_COMPANY_UPI_ID=
EXPO_PUBLIC_COMPANY_UPI_NAME="Solar Payments"
