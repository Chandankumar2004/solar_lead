PORT=4000
NODE_ENV=development
# For Render env vars, paste raw values without wrapping quotes.
# Runtime (Prisma client): use DATABASE_URL only (transaction pooler)
DATABASE_URL=postgresql://postgres.onblngbhnigulspucvwg:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
# DIRECT_URL is kept for local migrations/introspection (direct host)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.onblngbhnigulspucvwg.supabase.co:5432/postgres?sslmode=require
PUBLIC_LEAD_MIN_MONTHLY_BILL_INR=500
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

JWT_ACCESS_SECRET="replace-with-64+char-random"
JWT_REFRESH_SECRET="replace-with-64+char-random"
# Optional explicit key for encrypting customer sensitive fields (Aadhaar/PAN/Bank Account).
# Use a 32-byte base64 key for production. If omitted, API falls back to JWT/service-role secret hashing.
CUSTOMER_DATA_ENCRYPTION_KEY=
RECAPTCHA_SECRET_KEY=replace_me
# Optional reCAPTCHA aliases supported in code:
GOOGLE_RECAPTCHA_SECRET_KEY=
RECAPTCHA_SECRET=
GOOGLE_RECAPTCHA_SECRET=
# Optional override for admin login reCAPTCHA enforcement.
# Defaults to true in production and false in development.
# Set false for local testing when Google blocks localhost tokens.
RECAPTCHA_ENFORCE_LOGIN=false
# Optional override for public lead form reCAPTCHA enforcement.
# Defaults to true in production and false in development.
RECAPTCHA_ENFORCE_PUBLIC_LEAD=false
WEB_ORIGIN=http://localhost:3200,https://solar-lead-web.vercel.app
# Optional aliases (if your Render env uses these names)
CORS_ORIGIN=https://solar-lead-web.vercel.app
FRONTEND_URL=https://solar-lead-web.vercel.app
ADMIN_PORTAL_URL=https://solar-lead-web.vercel.app
SETUP_PASSWORD_TOKEN_TTL_HOURS=48

FIREBASE_PROJECT_ID="solar-ac76e"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-fbsvc@solar-ac76e.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Redis (Bull queue)
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=5
BULL_NOTIFICATION_QUEUE=notification-dispatch
# 0 disables inactivity reminders. Any positive value means "inactive for N days".
LEAD_INACTIVITY_REMINDER_DAYS=3
# Optional SLA sweep interval override in milliseconds.
SLA_CHECK_INTERVAL_MS=60000
TOKEN_PAYMENT_AMOUNT_INR=1000

# Supabase Storage (documents via signed URLs)
# Bucket is private and accessed only via backend-signed URLs.
# Default bucket: documents
SUPABASE_DOCUMENTS_BUCKET=documents
# Signed URL expiry in seconds (default 15 minutes).
DOCUMENT_SIGNED_URL_EXPIRES_SECONDS=900
# Required keys are SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
