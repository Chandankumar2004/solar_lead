generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE      @map("active")
  PENDING     @map("pending")
  SUSPENDED   @map("suspended")
  DEACTIVATED @map("deactivated")
}

enum UserRole {
  SUPER_ADMIN @map("super_admin")
  ADMIN       @map("admin")
  MANAGER     @map("manager")
  EXECUTIVE   @map("executive")
}

enum DocumentReviewStatus {
  PENDING  @map("pending")
  VERIFIED @map("verified")
  REJECTED @map("rejected")
}

enum PaymentStatus {
  PENDING  @map("pending")
  VERIFIED @map("verified")
  REJECTED @map("rejected")
}

enum PaymentMethod {
  UPI_GATEWAY @map("upi_gateway")
  QR_UTR      @map("qr_utr")
}

enum NotificationChannel {
  SMS      @map("sms")
  EMAIL    @map("email")
  WHATSAPP @map("whatsapp")
  PUSH     @map("push")
}

enum DevicePlatform {
  WEB
  ANDROID
  IOS
}

model User {
  id               String                   @id @default(uuid()) @db.Uuid
  email            String                   @unique
  passwordHash     String                   @map("password_hash")
  fullName         String                   @map("full_name")
  phone            String?
  role             UserRole
  employeeId       String?                  @unique @map("employee_id")
  status           UserStatus               @default(PENDING)
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  lastLoginAt      DateTime?                @map("last_login_at")
  districts        UserDistrictAssignment[]
  assignedAsExec   Lead[]                   @relation("LeadAssignedExecutive")
  assignedAsMgr    Lead[]                   @relation("LeadAssignedManager")
  statusHistory    LeadStatusHistory[]
  uploadedDocs     Document[]               @relation("DocumentsUploadedBy")
  reviewedDocs     Document[]               @relation("DocumentsReviewedBy")
  collectedPayment Payment[]                @relation("PaymentCollectedBy")
  verifiedPayment  Payment[]                @relation("PaymentVerifiedBy")
  auditLogs        AuditLog[]
  deviceTokens     UserDeviceToken[]
  chatConversationsCreated    ChatConversation[]         @relation("ChatConversationCreatedBy")
  chatConversationParticipants ChatConversationParticipant[]
  chatMessagesSent            ChatMessage[]              @relation("ChatMessageSender")
  setupPasswordTokens        UserSetupPasswordToken[] @relation("UserSetupTokenUser")
  issuedSetupPasswordTokens  UserSetupPasswordToken[] @relation("UserSetupTokenIssuer")

  @@index([role, status])
  @@index([status])
  @@map("users")
}

model UserSetupPasswordToken {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  issuedByUserId String?   @map("issued_by_user_id") @db.Uuid
  tokenHash      String    @unique @map("token_hash")
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation("UserSetupTokenUser", fields: [userId], references: [id], onDelete: Cascade)
  issuedByUser   User?     @relation("UserSetupTokenIssuer", fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, usedAt, expiresAt])
  @@index([issuedByUserId])
  @@map("user_setup_password_tokens")
}

model District {
  id              String                   @id @default(uuid()) @db.Uuid
  name            String
  state           String
  isActive        Boolean                  @default(true) @map("is_active")
  createdAt       DateTime                 @default(now()) @map("created_at")
  assignments     UserDistrictAssignment[]
  leads           Lead[]
  customerDetails CustomerDetail[]

  @@unique([name, state])
  @@index([state, isActive])
  @@map("districts")
}

model UserDistrictAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  districtId String   @map("district_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([userId, districtId])
  @@index([districtId])
  @@index([userId])
  @@map("user_district_assignments")
}

model UserDeviceToken {
  id         String         @id @default(uuid()) @db.Uuid
  userId     String         @map("user_id") @db.Uuid
  token      String         @unique
  platform   DevicePlatform
  deviceId   String?        @map("device_id")
  appVersion String?        @map("app_version")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  lastSeenAt DateTime       @default(now()) @map("last_seen_at")
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId, platform])
  @@map("user_device_tokens")
}

model AssignmentConfig {
  id                        String   @id @default(uuid()) @db.Uuid
  scope                     String   @unique @default("GLOBAL")
  maxActiveLeadsPerExecutive Int      @default(50) @map("max_active_leads_per_executive")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("assignment_configs")
}

model LeadStatus {
  id                     String                 @id @default(uuid()) @db.Uuid
  name                   String                 @unique
  description            String?
  orderIndex             Int                    @map("order_index")
  isTerminal             Boolean                @default(false) @map("is_terminal")
  slaDurationHours       Int?                   @map("sla_duration_hours")
  colorCode              String?                @map("color_code")
  requiresNote           Boolean                @default(false) @map("requires_note")
  requiresDocument       Boolean                @default(false) @map("requires_document")
  notifyCustomer         Boolean                @default(false) @map("notify_customer")
  notificationTemplateId String?                @map("notification_template_id") @db.Uuid
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  notificationTemplate   NotificationTemplate?  @relation(fields: [notificationTemplateId], references: [id], onDelete: SetNull)
  fromTransitions        LeadStatusTransition[] @relation("StatusTransitionFrom")
  toTransitions          LeadStatusTransition[] @relation("StatusTransitionTo")
  leads                  Lead[]
  fromHistory            LeadStatusHistory[]    @relation("StatusHistoryFrom")
  toHistory              LeadStatusHistory[]    @relation("StatusHistoryTo")

  @@index([orderIndex])
  @@index([isTerminal])
  @@map("lead_statuses")
}

model LeadStatusTransition {
  id           String     @id @default(uuid()) @db.Uuid
  fromStatusId String     @map("from_status_id") @db.Uuid
  toStatusId   String     @map("to_status_id") @db.Uuid
  fromStatus   LeadStatus @relation("StatusTransitionFrom", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus     LeadStatus @relation("StatusTransitionTo", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([fromStatusId, toStatusId])
  @@index([fromStatusId])
  @@index([toStatusId])
  @@map("lead_status_transitions")
}

model Lead {
  id                  String              @id @default(uuid()) @db.Uuid
  externalId          String              @unique @default(uuid()) @map("external_id") @db.Uuid
  name                String
  phone               String
  email               String?
  monthlyBill         Decimal?            @map("monthly_bill") @db.Decimal(12, 2)
  districtId          String              @map("district_id") @db.Uuid
  state               String?
  installationType    String?             @map("installation_type")
  message             String?
  currentStatusId     String              @map("current_status_id") @db.Uuid
  assignedExecutiveId String?             @map("assigned_executive_id") @db.Uuid
  assignedManagerId   String?             @map("assigned_manager_id") @db.Uuid
  utmSource           String?             @map("utm_source")
  utmMedium           String?             @map("utm_medium")
  utmCampaign         String?             @map("utm_campaign")
  utmTerm             String?             @map("utm_term")
  utmContent          String?             @map("utm_content")
  sourceIp            String?             @map("source_ip")
  recaptchaScore      Decimal?            @map("recaptcha_score") @db.Decimal(5, 4)
  consentGiven        Boolean             @default(false) @map("consent_given")
  consentTimestamp    DateTime?           @map("consent_timestamp")
  consentIpAddress    String?             @map("consent_ip_address")
  emailOptOut         Boolean             @default(false) @map("email_opt_out")
  whatsappOptOut      Boolean             @default(false) @map("whatsapp_opt_out")
  smsDndStatus        Boolean             @default(false) @map("sms_dnd_status")
  optOutTimestamp     DateTime?           @map("opt_out_timestamp")
  optOutSource        String?             @map("opt_out_source")
  statusUpdatedAt     DateTime            @default(now()) @map("status_updated_at")
  isOverdue           Boolean             @default(false) @map("is_overdue")
  overdueAt           DateTime?           @map("overdue_at")
  noExecutiveAvailable Boolean            @default(false) @map("no_executive_available")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  district            District            @relation(fields: [districtId], references: [id])
  currentStatus       LeadStatus          @relation(fields: [currentStatusId], references: [id])
  assignedExecutive   User?               @relation("LeadAssignedExecutive", fields: [assignedExecutiveId], references: [id], onDelete: SetNull)
  assignedManager     User?               @relation("LeadAssignedManager", fields: [assignedManagerId], references: [id], onDelete: SetNull)
  statusHistory       LeadStatusHistory[]
  customerDetail      CustomerDetail?
  documents           Document[]
  payments            Payment[]
  paymentWebhookEvents PaymentWebhookEvent[]
  notificationLogs    NotificationLog[]
  loanDetails         LoanDetail?
  chatConversations   ChatConversation[]

  @@index([districtId])
  @@index([currentStatusId])
  @@index([assignedExecutiveId])
  @@index([assignedManagerId])
  @@index([districtId, currentStatusId])
  @@index([assignedExecutiveId, currentStatusId])
  @@index([isOverdue])
  @@index([statusUpdatedAt])
  @@index([isOverdue, statusUpdatedAt])
  @@index([noExecutiveAvailable])
  @@index([createdAt])
  @@index([phone])
  @@index([email])
  @@index([emailOptOut])
  @@index([whatsappOptOut])
  @@index([smsDndStatus])
  @@map("leads")
}

model ChatConversation {
  id              String                        @id @default(uuid()) @db.Uuid
  key             String                        @unique @map("conversation_key")
  type            String                        @default("DIRECT")
  leadId          String?                       @map("lead_id") @db.Uuid
  districtId      String?                       @map("district_id") @db.Uuid
  createdByUserId String                        @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                      @default(now()) @map("created_at")
  updatedAt       DateTime                      @updatedAt @map("updated_at")
  lastMessageAt   DateTime                      @default(now()) @map("last_message_at")
  lead            Lead?                         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdByUser   User                          @relation("ChatConversationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  participants    ChatConversationParticipant[]
  messages        ChatMessage[]

  @@index([leadId])
  @@index([districtId])
  @@index([type, updatedAt])
  @@index([lastMessageAt])
  @@map("chat_conversations")
}

model ChatConversationParticipant {
  id             String           @id @default(uuid()) @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  joinedAt       DateTime         @default(now()) @map("joined_at")
  lastReadAt     DateTime?        @map("last_read_at")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId, lastReadAt])
  @@map("chat_conversation_participants")
}

model ChatMessage {
  id             String           @id @default(uuid()) @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  senderUserId   String           @map("sender_user_id") @db.Uuid
  body           String
  createdAt      DateTime         @default(now()) @map("created_at")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser     User             @relation("ChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
  @@map("chat_messages")
}

model LeadStatusHistory {
  id              String      @id @default(uuid()) @db.Uuid
  leadId          String      @map("lead_id") @db.Uuid
  fromStatusId    String?     @map("from_status_id") @db.Uuid
  toStatusId      String      @map("to_status_id") @db.Uuid
  changedByUserId String      @map("changed_by_user_id") @db.Uuid
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus      LeadStatus? @relation("StatusHistoryFrom", fields: [fromStatusId], references: [id], onDelete: SetNull)
  toStatus        LeadStatus  @relation("StatusHistoryTo", fields: [toStatusId], references: [id])
  changedByUser   User        @relation(fields: [changedByUserId], references: [id])

  @@index([leadId])
  @@index([leadId, createdAt])
  @@index([changedByUserId])
  @@map("lead_status_history")
}

model CustomerDetail {
  id                   String    @id @default(uuid()) @db.Uuid
  leadId               String    @unique @map("lead_id") @db.Uuid
  fullName             String    @map("full_name")
  dateOfBirth          DateTime? @map("date_of_birth")
  gender               String?
  fatherHusbandName    String?   @map("father_husband_name")
  aadhaarEncrypted     String?   @map("aadhaar_encrypted")
  panEncrypted         String?   @map("pan_encrypted")
  addressLine1         String?   @map("address_line1")
  addressLine2         String?   @map("address_line2")
  villageLocality      String?   @map("village_locality")
  pincode              String?
  districtId           String?   @map("district_id") @db.Uuid
  alternatePhone       String?   @map("alternate_phone")
  propertyOwnership    String?   @map("property_ownership")
  roofArea             Decimal?  @map("roof_area") @db.Decimal(12, 2)
  recommendedCapacity  Decimal?  @map("recommended_capacity") @db.Decimal(10, 2)
  shadowFreeArea       Decimal?  @map("shadow_free_area") @db.Decimal(12, 2)
  roofType             String?   @map("roof_type")
  verifiedMonthlyBill  Decimal?  @map("verified_monthly_bill") @db.Decimal(12, 2)
  connectionType       String?   @map("connection_type")
  consumerNumber       String?   @map("consumer_number")
  discomName           String?   @map("discom_name")
  bankAccountEncrypted String?   @map("bank_account_encrypted")
  bankName             String?   @map("bank_name")
  ifscCode             String?   @map("ifsc_code")
  accountHolderName    String?   @map("account_holder_name")
  loanRequired         Boolean   @default(false) @map("loan_required")
  loanAmountRequired   Decimal?  @map("loan_amount_required") @db.Decimal(12, 2)
  preferredLender      String?   @map("preferred_lender")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  lead                 Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  district             District? @relation(fields: [districtId], references: [id], onDelete: SetNull)

  @@index([districtId])
  @@index([pincode])
  @@map("customer_details")
}

model Document {
  id               String               @id @default(uuid()) @db.Uuid
  leadId           String               @map("lead_id") @db.Uuid
  category         String
  s3Key            String               @map("s3_key")
  fileName         String               @map("file_name")
  fileType         String               @map("file_type")
  fileSize         Int                  @map("file_size")
  version          Int                  @default(1)
  isLatest         Boolean              @default(true) @map("is_latest")
  uploadedByUserId String?              @map("uploaded_by_user_id") @db.Uuid
  reviewStatus     DocumentReviewStatus @default(PENDING) @map("review_status")
  reviewNotes      String?              @map("review_notes")
  reviewedByUserId String?              @map("reviewed_by_user_id") @db.Uuid
  reviewedAt       DateTime?            @map("reviewed_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  lead             Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploadedByUser   User?                @relation("DocumentsUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  reviewedByUser   User?                @relation("DocumentsReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([leadId, category, version])
  @@index([leadId])
  @@index([leadId, isLatest])
  @@index([reviewStatus])
  @@index([uploadedByUserId])
  @@map("documents")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  leadId            String        @map("lead_id") @db.Uuid
  amount            Decimal       @db.Decimal(12, 2)
  method            PaymentMethod
  provider          String?
  upiId             String?       @map("upi_id")
  gatewayOrderId    String?       @map("gateway_order_id")
  gatewayRequestId  String?       @map("gateway_request_id")
  gatewayPaymentId  String?       @map("gateway_payment_id")
  gatewayStatus     String?       @map("gateway_status")
  webhookReferenceId String?      @map("webhook_reference_id")
  providerPayload   Json?         @map("provider_payload")
  utrNumber         String?       @map("utr_number")
  status            PaymentStatus @default(PENDING)
  collectedByUserId String?       @map("collected_by_user_id") @db.Uuid
  verifiedByUserId  String?       @map("verified_by_user_id") @db.Uuid
  rejectionReason   String?       @map("rejection_reason")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  verifiedAt        DateTime?     @map("verified_at")
  lead              Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  collectedByUser   User?         @relation("PaymentCollectedBy", fields: [collectedByUserId], references: [id], onDelete: SetNull)
  verifiedByUser    User?         @relation("PaymentVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  webhookEvents     PaymentWebhookEvent[]

  @@index([leadId])
  @@index([leadId, status])
  @@index([status, method])
  @@index([method])
  @@index([provider])
  @@index([gatewayOrderId])
  @@index([gatewayPaymentId])
  @@index([gatewayRequestId])
  @@index([webhookReferenceId])
  @@index([collectedByUserId])
  @@index([verifiedByUserId])
  @@map("payments")
}

model PaymentWebhookEvent {
  id               String    @id @default(uuid()) @db.Uuid
  provider         String
  eventId          String    @unique @map("event_id")
  eventType        String    @map("event_type")
  paymentId        String?   @map("payment_id") @db.Uuid
  leadId           String?   @map("lead_id") @db.Uuid
  gatewayOrderId   String?   @map("gateway_order_id")
  gatewayPaymentId String?   @map("gateway_payment_id")
  signature        String?
  payload          Json
  processed        Boolean   @default(false)
  processingNote   String?   @map("processing_note")
  processedAt      DateTime? @map("processed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  payment          Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([provider, eventType])
  @@index([paymentId])
  @@index([leadId])
  @@index([gatewayOrderId])
  @@index([gatewayPaymentId])
  @@map("payment_webhook_events")
}

model NotificationTemplate {
  id               String              @id @default(uuid()) @db.Uuid
  name             String              @unique
  channel          NotificationChannel
  subject          String?
  bodyTemplate     String              @map("body_template")
  isActive         Boolean             @default(true) @map("is_active")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  leadStatuses     LeadStatus[]
  notificationLogs NotificationLog[]

  @@index([channel, isActive])
  @@map("notification_templates")
}

model NotificationLog {
  id                String                @id @default(uuid()) @db.Uuid
  leadId            String?               @map("lead_id") @db.Uuid
  channel           NotificationChannel
  templateId        String?               @map("template_id") @db.Uuid
  recipient         String
  contentSent       String                @map("content_sent")
  deliveryStatus    String                @map("delivery_status")
  providerMessageId String?               @map("provider_message_id")
  attempts          Int                   @default(0)
  createdAt         DateTime              @default(now()) @map("created_at")
  lastAttemptedAt   DateTime?             @map("last_attempted_at")
  lead              Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  template          NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([channel, createdAt])
  @@index([templateId])
  @@index([deliveryStatus])
  @@map("notification_logs")
}

model LoanDetail {
  id                String    @id @default(uuid()) @db.Uuid
  leadId            String    @unique @map("lead_id") @db.Uuid
  lenderName        String    @map("lender_name")
  applicationNumber String?   @map("application_number")
  appliedAmount     Decimal?  @map("applied_amount") @db.Decimal(12, 2)
  approvedAmount    Decimal?  @map("approved_amount") @db.Decimal(12, 2)
  applicationStatus String    @map("application_status")
  appliedAt         DateTime? @map("applied_at")
  approvedAt        DateTime? @map("approved_at")
  disbursedAt       DateTime? @map("disbursed_at")
  rejectionReason   String?   @map("rejection_reason")
  notes             String?
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lead              Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([applicationStatus])
  @@index([lenderName])
  @@map("loan_details")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  detailsJson Json?    @map("details_json")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PublicLeadSubmission {
  id                   String   @id @db.Uuid
  externalId           String   @unique @map("external_id") @db.Uuid
  name                 String
  phone                String
  email                String?
  monthlyBill          Decimal? @map("monthly_bill") @db.Decimal(12, 2)
  districtId           String   @map("district_id") @db.Uuid
  districtName         String   @map("district_name")
  state                String
  installationType     String?  @map("installation_type")
  message              String?
  consentGiven         Boolean  @default(false) @map("consent_given")
  consentTimestamp     DateTime? @map("consent_timestamp") @db.Timestamptz(6)
  consentIpAddress     String?  @map("consent_ip_address")
  sourceIp             String?  @map("source_ip")
  recaptchaScore       Decimal? @map("recaptcha_score") @db.Decimal(5, 4)
  utmSource            String?  @map("utm_source")
  utmMedium            String?  @map("utm_medium")
  utmCampaign          String?  @map("utm_campaign")
  utmTerm              String?  @map("utm_term")
  utmContent           String?  @map("utm_content")
  smsDeliveryStatus    String?  @map("sms_delivery_status")
  smsProviderMessageId String?  @map("sms_provider_message_id")
  smsError             String?  @map("sms_error")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "idx_public_lead_submissions_created_at")
  @@index([phone], map: "idx_public_lead_submissions_phone")
  @@map("public_lead_submissions")
}
